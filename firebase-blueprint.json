{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "allowSearch": { "type": "boolean" },
        "chocolateBalance": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "profilePic": { "type": "string" },
        "blockedUsers": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["firstName", "lastName", "email", "phone", "allowSearch", "createdAt"]
    },
    "Letter": {
      "title": "Letter",
      "description": "A digital letter sent between users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "preview": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "chocolateAmount": { "type": "integer" },
        "chocolateStatus": { "type": "string", "enum": ["none", "pending", "accepted", "rejected"] },
        "status": { "type": "string", "enum": ["sent", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "content", "preview", "isAnonymous", "chocolateStatus", "status", "createdAt"]
    },
    "SearchIndex": {
      "title": "Search Index",
      "description": "Mapping of phone numbers to user IDs for searching",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "allowSearch": { "type": "boolean" }
      },
      "required": ["userId", "firstName", "lastName", "allowSearch"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/letters/{letterId}": {
      "schema": "Letter",
      "description": "Letter documents"
    },
    "/search_index/{phone}": {
      "schema": "SearchIndex",
      "description": "Search index by phone number"
    }
  }
}
